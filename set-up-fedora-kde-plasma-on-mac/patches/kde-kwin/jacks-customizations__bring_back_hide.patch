-                 Qt::META | Qt::Key_PageDown, &Workspace::slotWindowMinimize);
+                 Qt::CTRL | Qt::Key_H, &Workspace::slotWindowMinimize);
+    initShortcut("Window Minimize Others", "Minimize Other Windows",
